FROM library/python:2.7.18-alpine AS builder
# FROM maven:3.8.8-eclipse-temurin-8-alpine as builder

LABEL maintainer=ttchengwang@foxmail.com

RUN apk add openjdk8
RUN apk add maven
RUN apk add git

RUN echo 'export JAVA_HOME=/usr/lib/jvm/java-1.8-openjdk' >> /etc/profile && \
    echo 'export PATH=$JAVA_HOME/bin:$PATH' >> /etc/profile && \
    echo '#jdk8' >> /etc/profile

RUN java -version
ENV BUILD_DIR=/workspace/disconf
ENV ONLINE_CONFIG_PATH=/disconf/conf
ENV WAR_ROOT_PATH=/disconf

COPY conf/application.properties  $ONLINE_CONFIG_PATH/application.properties
COPY conf/jdbc-mysql.properties  $ONLINE_CONFIG_PATH/jdbc-mysql.properties
COPY conf/redis-config.properties  $ONLINE_CONFIG_PATH/redis-config.properties
COPY conf/zoo.properties  $ONLINE_CONFIG_PATH/zoo.properties

WORKDIR $BUILD_DIR
RUN git clone https://gitee.com/mirrors/disconf.git && \
    cd disconf && \
    git checkout 2.6.36 && \
    cd disconf-web && \
    source /etc/profile && \
    sh deploy/deploy.sh

FROM library/tomcat:9.0.115-jdk8 AS production

RUN apt-get update && \
    apt-get install -y nginx && \
    apt-get clean && \
    rm -rf /var/lib/apt/lists/*

RUN mkdir $CATALINA_HOME/webapps/ROOT
COPY --from=builder --chown=root:root /disconf/disconf-web.war $CATALINA_HOME/webapps/ROOT
RUN cd $CATALINA_HOME/webapps/ROOT && jar xvf disconf-web.war && rm disconf-web.war

RUN groupadd nginx && useradd nginx -g nginx
COPY --from=builder --chown=nginx:nginx /disconf/html /usr/share/nginx/html

CMD ["/bin/sh","-c","nginx && catalina.sh run"]
