FROM docker.1ms.run/library/python:2.7.18-alpine AS builder
# FROM docker.1ms.run/maven:3.8.8-eclipse-temurin-8-alpine as builder

LABEL maintainer=ttchengwang@foxmail.com

# 国内软件源
RUN sed -i 's/dl-cdn.alpinelinux.org/mirrors.aliyun.com/g' /etc/apk/repositories

RUN apk add openjdk8
RUN apk add maven
RUN apk add git

# pyhon 软件源
ENV PIP_INDEX_URL=https://mirrors.aliyun.com/pypi/simple/
ENV PIP_TRUSTED_HOST=mirrors.aliyun.com
# maven 仓库镜像源
RUN mkdir -p /root/.m2 && echo '<?xml version="1.0" encoding="UTF-8"?>\
<settings xmlns="http://maven.apache.org/SETTINGS/1.0.0"\
          xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"\
          xsi:schemaLocation="http://maven.apache.org/SETTINGS/1.0.0 http://maven.apache.org/xsd/settings-1.0.0.xsd">\
  <mirrors>\
    <mirror>\
      <id>aliyunmaven</id>\
      <mirrorOf>central</mirrorOf>\
      <url>https://maven.aliyun.com/repository/public</url>\
    </mirror>\
  </mirrors>\
</settings>' > /root/.m2/settings.xml
RUN mvn help:effective-settings

RUN echo 'export JAVA_HOME=/usr/lib/jvm/java-1.8-openjdk' >> /etc/profile && \
    echo 'export PATH=$JAVA_HOME/bin:$PATH' >> /etc/profile && \
    echo '#jdk8' >> /etc/profile

RUN java -version
ENV BUILD_DIR=/workspace
ENV ONLINE_CONFIG_PATH=/disconf/conf
ENV WAR_ROOT_PATH=/disconf

COPY conf/application.properties  $ONLINE_CONFIG_PATH/application.properties
COPY conf/jdbc-mysql.properties  $ONLINE_CONFIG_PATH/jdbc-mysql.properties
COPY conf/redis-config.properties  $ONLINE_CONFIG_PATH/redis-config.properties
COPY conf/zoo.properties  $ONLINE_CONFIG_PATH/zoo.properties

WORKDIR $BUILD_DIR
RUN git clone https://gitee.com/mirrors/disconf.git && \
    cd disconf && \
    git checkout 2.6.36 && \
    cd disconf-web && \
    source /etc/profile && \
    sh deploy/deploy.sh

FROM docker.1ms.run/library/tomcat:9.0.115-jdk8 AS backend

RUN sed -i 's/archive.ubuntu.com/mirrors.tuna.tsinghua.edu.cn/g' /etc/apt/sources.list.d/ubuntu.sources && \
    sed -i 's/security.ubuntu.com/mirrors.tuna.tsinghua.edu.cn/g' /etc/apt/sources.list.d/ubuntu.sources && \
    apt-get update && \
    apt-get clean && \
    rm -rf /var/lib/apt/lists/*

# RUN sed -i 's/<\/Host>/<Context path="" docBase="\/disconf\/ROOT"\/><\/Host>/' /usr/local/tomcat/conf/server.xml \

RUN mkdir $CATALINA_HOME/webapps/ROOT
COPY --from=builder --chown=root:root /disconf/disconf-web.war $CATALINA_HOME/webapps/ROOT
RUN cd $CATALINA_HOME/webapps/ROOT && jar xvf disconf-web.war && rm disconf-web.war
CMD ["catalina.sh", "run"]

FROM docker.1ms.run/library/nginx:stable-alpine AS frontend
COPY --from=builder --chown=nginx:nginx /disconf/html /usr/share/nginx/html

FROM docker.1ms.run/library/mysql:5.7-debian AS database
COPY --from=builder --chown=mysql:mysql /workspace/disconf/disconf-web/sql /docker-entrypoint-initdb.d
RUN cd /docker-entrypoint-initdb.d && mv 201512/20151225.sql 3-patch1.sql && mv 20160701/20160701.sql 4-patch2.sql
